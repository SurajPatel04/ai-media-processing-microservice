# ==========================================
# CAMARIN AI - WORKER ENVIRONMENT VARIABLES
# ==========================================

# SERVER
PORT=8001
NODE_ENV=development

# DATABASE
MONGODB_URL=mongodb://localhost:27017
DB_NAME=camarin-ai

# REDIS (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# SUPABASE STORAGE
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_or_service_key
SUPABASE_BUCKET=your_storage_bucket_name

# AI SERVICES (LangChain / Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
CAPTION_MODEL=gemini-2.5-flash

# GOOGLE CLOUD VISION (Safe Search / Label Detection)
# Auth method 1 (production): point to a service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json
#
# Auth method 2 (local dev): run `gcloud auth application-default login`
# — no env var needed, SDK auto-discovers ~/.config/gcloud/application_default_credentials.json
